{
  "name": "nestica",
  "displayName": "Nestica",
  "description": "Color nested (), {}, and [] in different colors for better readability and block indentation.",
  "version": "0.4.0",
  "publisher": "SerhiiPimenov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/olton/nestica.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/index.js",
  "contributes": {
    "commands": [
      {
        "command": "nestica.refresh",
        "title": "Nestica: Refresh"
      },
      {
        "command": "nestica.showOutput",
        "title": "Nestica: Show Output"
      }
    ],
    "configurationDefaults": {
      "editor.bracketPairColorization.enabled": false
    },
    "configuration": {
      "title": "Nestica Settings",
      "properties": {
        "nestica.brackets.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable nestica bracket colorization."
        },
        "nestica.palette": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "pastel",
            "neon",
            "earthy",
            "solarized",
            "monochrome",
            "candypop",
            "retro",
            "ocean",
            "galaxy"
          ],
          "description": "Built-in palette used for adaptive dark/light colors when nestica.colors is empty."
        },
        "nestica.colors": {
          "type": "array",
          "default": [],
          "description": "Optional custom colors for bracket nesting levels. Leave empty to use built-in adaptive palettes for dark/light themes.",
          "items": {
            "type": "string"
          }
        },
        "nestica.guides.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable colored vertical guide lines for bracket blocks."
        },
        "nestica.guides.thickness": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 6,
          "description": "Guide line thickness in pixels."
        },
        "nestica.guides.opacity": {
          "type": "number",
          "default": 0.3,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Guide line opacity from 0.1 to 1. Default is 0.3 for a subtle effect."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "npm run build",
    "vscode:prepublish": "npm run package",
    "check": "tsc --noEmit -p .",
    "compile": "vsce package"
  },
  "keywords": [
    "vscode",
    "extension",
    "brackets",
    "color",
    "nestica",
    "guides",
    "indentation",
    "nested",
    "parentheses",
    "curly braces",
    "square brackets"
  ],
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
