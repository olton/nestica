{
  "name": "rainbow",
  "displayName": "Rainbow",
  "description": "Color nested (), {}, and [] in different colors for better readability and block indentation.",
  "version": "0.1.0",
  "publisher": "SerhiiPimenov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/olton/rainbow.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/index.js",
  "contributes": {
    "commands": [
      {
        "command": "rainbow.refresh",
        "title": "Rainbow: Refresh"
      }
    ],
    "configuration": {
      "title": "Rainbow",
      "properties": {
        "rainbow.brackets.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable rainbow bracket colorization."
        },
        "rainbow.colors": {
          "type": "array",
          "default": [
            "#E06C75",
            "#E5C07B",
            "#98C379",
            "#56B6C2",
            "#61AFEF",
            "#C678DD",
            "#BE5046",
            "#D19A66",
            "#AF1320"
          ],
          "description": "List of colors used to paint bracket nesting levels.",
          "items": {
            "type": "string"
          }
        },
        "rainbow.guides.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable colored vertical guide lines for bracket blocks."
        },
        "rainbow.guides.thickness": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 6,
          "description": "Guide line thickness in pixels."
        },
        "rainbow.guides.opacity": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.1,
          "maximum": 1,
          "description": "Guide line opacity from 0.1 to 1."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "npm run build",
    "vscode:prepublish": "npm run package"
  },
  "keywords": [
    "vscode",
    "extension",
    "brackets",
    "color",
    "rainbow",
    "guides",
    "indentation"
  ],
  "devDependencies": {
    "@types/node": "^22.19.18",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}
